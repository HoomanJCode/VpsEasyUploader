# VpsEasyUploader Configuration
# Copy this file to .env and fill in your values, or run ./setup.sh

# Server IP address (0.0.0.0 = listen on all interfaces)
IP=0.0.0.0

# Server port
PORT=8080

# Flask secret key (auto-generated by setup.sh)
SECRET_KEY=change-me-to-a-random-string

# Logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=WARNING

# TUS hook secret (auto-generated on first run — do not change)
# TUSD_HOOK_SECRET=

# Optional: domain name for HTTPS
# DOMAIN=

# Optional: SSL certificate paths (required if DOMAIN is set)
# SSL_CERT=
# SSL_KEY=
